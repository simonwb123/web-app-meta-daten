<!DOCTYPE html>
<html>
<head>
<script src="https://cdnjs.cloudflare.com/ajax/libs/piexifjs/1.0.6/piexif.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font-sans); background: transparent; color: var(--color-text-primary); }
.app { max-width: 480px; margin: 0 auto; padding: 1rem; }
.header { margin-bottom: 1.25rem; }
.header h2 { font-size: 18px; font-weight: 500; }
.header p { font-size: 13px; color: var(--color-text-secondary); margin-top: 2px; }
.status-bar { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: var(--color-background-secondary); border-radius: var(--border-radius-md); border: 0.5px solid var(--color-border-tertiary); margin-bottom: 1rem; font-size: 13px; }
.dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.dot.green { background: #639922; }
.dot.amber { background: #BA7517; }
.dot.red { background: #E24B4A; }
.dot.gray { background: #888780; }
.camera-area { position: relative; background: #1a1a1a; border-radius: var(--border-radius-lg); border: 0.5px solid var(--color-border-tertiary); overflow: hidden; aspect-ratio: 4/3; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; }
#videoEl, #canvasEl { width: 100%; height: 100%; object-fit: cover; display: none; border-radius: var(--border-radius-lg); }
.camera-placeholder { display: flex; flex-direction: column; align-items: center; gap: 8px; color: #888; }
.camera-icon { font-size: 40px; }
.camera-placeholder p { font-size: 13px; }
.gps-overlay { position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.65); color: #fff; font-size: 11px; padding: 5px 9px; border-radius: 6px; font-family: var(--font-mono); display: none; }
.controls { display: flex; flex-direction: column; gap: 10px; }
.btn-row { display: flex; gap: 8px; }
button { flex: 1; padding: 10px 16px; border-radius: var(--border-radius-md); border: 0.5px solid var(--color-border-secondary); background: transparent; color: var(--color-text-primary); font-size: 14px; cursor: pointer; font-family: var(--font-sans); }
button:hover { background: var(--color-background-secondary); }
button:active { transform: scale(0.98); }
button:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
button.primary { background: var(--color-background-primary); border: 0.5px solid var(--color-border-primary); font-weight: 500; }
.shutter-btn { width: 60px; height: 60px; flex: none; border-radius: 50%; background: #fff; border: 3px solid var(--color-border-secondary); margin: 0 auto; }
.shutter-btn:hover { background: #e8e8e8; }
.meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.meta-card { background: var(--color-background-secondary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-md); padding: 10px 12px; }
.meta-card .label { font-size: 11px; color: var(--color-text-secondary); margin-bottom: 3px; }
.meta-card .value { font-size: 13px; font-weight: 500; font-family: var(--font-mono); }
.result-card { display: none; background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1rem; margin-top: 1rem; }
.result-card h3 { font-size: 14px; font-weight: 500; margin-bottom: 10px; }
.result-img { width: 100%; border-radius: var(--border-radius-md); margin-bottom: 10px; }
.exif-list { font-size: 12px; color: var(--color-text-secondary); font-family: var(--font-mono); line-height: 1.8; }
.exif-list span { color: var(--color-text-primary); }
#downloadBtn { display: none; }
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <h2>GPS-Kamera</h2>
    <p>Fotos mit eingebetteten GPS-EXIF-Tags aufnehmen</p>
  </div>
  <div class="status-bar">
    <div class="dot gray" id="gpsDot"></div>
    <span id="gpsStatusText">GPS: Warte auf Berechtigung...</span>
  </div>
  <div class="camera-area" id="cameraArea">
    <div class="camera-placeholder" id="placeholder">
      <div class="camera-icon">&#128247;</div>
      <p>Kamera starten um aufzunehmen</p>
    </div>
    <video id="videoEl" autoplay playsinline></video>
    <canvas id="canvasEl"></canvas>
    <div class="gps-overlay" id="gpsOverlay"></div>
  </div>
  <div class="controls">
    <div class="btn-row">
      <button id="startCamBtn" class="primary" onclick="startCamera()">Kamera starten</button>
      <button id="gpsBtn" onclick="requestGPS()">GPS holen</button>
    </div>
    <button id="shutterBtn" class="shutter-btn" disabled onclick="capture()" title="Foto aufnehmen"></button>
    <div class="meta-grid" id="metaGrid">
      <div class="meta-card"><div class="label">Breitengrad</div><div class="value" id="latVal">—</div></div>
      <div class="meta-card"><div class="label">Längengrad</div><div class="value" id="lonVal">—</div></div>
      <div class="meta-card"><div class="label">Genauigkeit</div><div class="value" id="accVal">—</div></div>
      <div class="meta-card"><div class="label">Zeitstempel</div><div class="value" id="tsVal">—</div></div>
    </div>
    <button id="downloadBtn" onclick="downloadPhoto()">Foto herunterladen (.jpg mit EXIF)</button>
  </div>
  <div class="result-card" id="resultCard">
    <h3>Aufgenommenes Foto</h3>
    <img class="result-img" id="previewImg" />
    <div class="exif-list" id="exifList"></div>
  </div>
</div>

<script>
let stream = null, gpsCoords = null, capturedBlob = null;
let videoEl = document.getElementById('videoEl');
let canvasEl = document.getElementById('canvasEl');

function setGpsStatus(state, msg) {
  document.getElementById('gpsDot').className = 'dot ' + state;
  document.getElementById('gpsStatusText').textContent = msg;
}

function requestGPS() {
  setGpsStatus('amber', 'GPS: Wird abgefragt...');
  navigator.geolocation.getCurrentPosition(pos => {
    gpsCoords = pos.coords;
    let lat = gpsCoords.latitude.toFixed(6);
    let lon = gpsCoords.longitude.toFixed(6);
    let acc = Math.round(gpsCoords.accuracy);
    let now = new Date().toLocaleTimeString('de-DE');
    setGpsStatus('green', 'GPS: ' + lat + ', ' + lon);
    document.getElementById('latVal').textContent = lat + '°';
    document.getElementById('lonVal').textContent = lon + '°';
    document.getElementById('accVal').textContent = '±' + acc + ' m';
    document.getElementById('tsVal').textContent = now;
    document.getElementById('gpsOverlay').style.display = 'block';
    document.getElementById('gpsOverlay').textContent = lat + ', ' + lon;
    checkReady();
  }, err => {
    setGpsStatus('red', 'GPS: Fehler – ' + err.message);
  }, { enableHighAccuracy: true, timeout: 10000 });
}

async function startCamera() {
  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 1920 }, height: { ideal: 1080 } }
    });
    videoEl.srcObject = stream;
    videoEl.style.display = 'block';
    document.getElementById('placeholder').style.display = 'none';
    document.getElementById('startCamBtn').textContent = 'Kamera läuft';
    document.getElementById('startCamBtn').disabled = true;
    checkReady();
  } catch(e) {
    alert('Kamera konnte nicht gestartet werden: ' + e.message);
  }
}

function checkReady() {
  document.getElementById('shutterBtn').disabled = !(stream && gpsCoords);
}

function toExifGPS(decimal) {
  let d = Math.abs(decimal);
  let deg = Math.floor(d);
  let minFull = (d - deg) * 60;
  let min = Math.floor(minFull);
  let sec = Math.round((minFull - min) * 60 * 100);
  return [[deg, 1], [min, 1], [sec, 100]];
}

function capture() {
  canvasEl.width = videoEl.videoWidth;
  canvasEl.height = videoEl.videoHeight;
  canvasEl.getContext('2d').drawImage(videoEl, 0, 0);
  let jpegData = canvasEl.toDataURL('image/jpeg', 0.92);

  let now = new Date();
  let dateStr = now.getFullYear() + ':' +
    String(now.getMonth()+1).padStart(2,'0') + ':' +
    String(now.getDate()).padStart(2,'0') + ' ' +
    String(now.getHours()).padStart(2,'0') + ':' +
    String(now.getMinutes()).padStart(2,'0') + ':' +
    String(now.getSeconds()).padStart(2,'0');

  let lat = gpsCoords.latitude;
  let lon = gpsCoords.longitude;
  let alt = gpsCoords.altitude || 0;

  let exifObj = {
    '0th': {
      [piexif.ImageIFD.Make]: 'GPS-Kamera WebApp',
      [piexif.ImageIFD.Model]: 'Browser',
      [piexif.ImageIFD.DateTime]: dateStr,
      [piexif.ImageIFD.Software]: 'Levelbuild GPS Tool',
      [piexif.ImageIFD.XResolution]: [72, 1],
      [piexif.ImageIFD.YResolution]: [72, 1],
    },
    'Exif': {
      [piexif.ExifIFD.DateTimeOriginal]: dateStr,
      [piexif.ExifIFD.DateTimeDigitized]: dateStr,
    },
    'GPS': {
      [piexif.GPSIFD.GPSVersionIDs]: [2, 3, 0, 0],
      [piexif.GPSIFD.GPSLatitudeRef]: lat >= 0 ? 'N' : 'S',
      [piexif.GPSIFD.GPSLatitude]: toExifGPS(lat),
      [piexif.GPSIFD.GPSLongitudeRef]: lon >= 0 ? 'E' : 'W',
      [piexif.GPSIFD.GPSLongitude]: toExifGPS(lon),
      [piexif.GPSIFD.GPSAltitudeRef]: alt >= 0 ? 0 : 1,
      [piexif.GPSIFD.GPSAltitude]: [Math.round(Math.abs(alt) * 100), 100],
    }
  };

  let exifStr = piexif.dump(exifObj);
  let newJpeg = piexif.insert(exifStr, jpegData);

  let byteStr = atob(newJpeg.split(',')[1]);
  let ab = new ArrayBuffer(byteStr.length);
  let ia = new Uint8Array(ab);
  for (let i = 0; i < byteStr.length; i++) ia[i] = byteStr.charCodeAt(i);
  capturedBlob = new Blob([ab], { type: 'image/jpeg' });

  document.getElementById('previewImg').src = URL.createObjectURL(capturedBlob);
  document.getElementById('resultCard').style.display = 'block';
  document.getElementById('downloadBtn').style.display = 'block';

  document.getElementById('exifList').innerHTML =
    'GPSLatitude: <span>' + lat.toFixed(7) + ' (' + (lat >= 0 ? 'N' : 'S') + ')</span><br>' +
    'GPSLongitude: <span>' + lon.toFixed(7) + ' (' + (lon >= 0 ? 'E' : 'W') + ')</span><br>' +
    'Accuracy: <span>±' + Math.round(gpsCoords.accuracy) + ' m</span><br>' +
    'DateTime: <span>' + dateStr + '</span><br>' +
    'ByteOrder: <span>Little Endian (II) ✓</span><br>' +
    'Format: <span>JPEG / EXIF 2.3</span>';
}

function downloadPhoto() {
  if (!capturedBlob) return;
  let now = new Date();
  let fname = 'foto_' + now.getFullYear() +
    String(now.getMonth()+1).padStart(2,'0') +
    String(now.getDate()).padStart(2,'0') + '_' +
    String(now.getHours()).padStart(2,'0') +
    String(now.getMinutes()).padStart(2,'0') + '.jpg';
  let a = document.createElement('a');
  a.href = URL.createObjectURL(capturedBlob);
  a.download = fname;
  a.click();
}

requestGPS();
</script>
</body>
</html>
