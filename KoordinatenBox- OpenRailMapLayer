const streckeColor = { "5850": "#e8542a", "5904": "#1a6fbb", "5903": "#5db83a", "5010": "#9b59b6" };

L.geoJSON(betriebsstellen, {
  pointToLayer: (feature, latlng) => {
    const km = feature.properties.km;
    const icon = L.divIcon({
      className: '',
      html: `<div class="km-label" style="
        color:#222; font-size:10px; font-weight:700;
        white-space:nowrap; font-family:'Segoe UI',system-ui,sans-serif;
        text-shadow: 0 0 3px white, 0 0 3px white;
      ">km${km}</div>`,
      iconAnchor: [20, 10]
    });
    return L.marker(latlng, { icon });
  },
  onEachFeature: (feature, layer) => {
    const p = feature.properties;
    layer.bindPopup(
      `<b>${p.name}</b><br>` +
      `Strecke ${p.strecke} · km ${p.km}<br>` +
      `<small style="color:#888">${p.typ}</small>`
    );
  }
}).addTo(map);

let kmLabelsEnabled = true;

function updateKmLabelVisibility() {
  const show = kmLabelsEnabled && map.getZoom() >= 12;
  document.querySelectorAll('.km-label').forEach(el => {
    el.style.display = show ? '' : 'none';
  });
}

function toggleKmLabels() {
  kmLabelsEnabled = !kmLabelsEnabled;
  document.getElementById('km-toggle-btn').classList.toggle('on', kmLabelsEnabled);
  updateKmLabelVisibility();
}

map.on('zoomend', updateKmLabelVisibility);
updateKmLabelVisibility();

// ── Sprung zu Betriebsstelle / km ──
function clearKmHighlight() {
  if (kmHighlightMarker) { kmHighlightMarker.remove(); kmHighlightMarker = null; }
}

function parseKm(str) {
  return parseFloat(String(str).replace(',', '.'));
}

function interpolateKm(strecke, targetKm) {
  const features = betriebsstellen.features
    .filter(f => f.properties.strecke === strecke)
    .map(f => ({ km: parseKm(f.properties.km), coords: f.geometry.coordinates, name: f.properties.name }))
    .sort((a, b) => a.km - b.km);
  if (features.length === 0) return null;
  const exact = features.find(f => Math.abs(f.km - targetKm) < 0.001);
  if (exact) return { lat: exact.coords[1], lng: exact.coords[0], exact: true, name: exact.name };
  const before = [...features].reverse().find(f => f.km < targetKm);
  const after  = features.find(f => f.km > targetKm);
  if (!before && !after) return null;
  if (!before) return { lat: after.coords[1],  lng: after.coords[0],  exact: false, name: null };
  if (!after)  return { lat: before.coords[1], lng: before.coords[0], exact: false, name: null };
  const t = (targetKm - before.km) / (after.km - before.km);
  return {
    lat: before.coords[1] + t * (after.coords[1] - before.coords[1]),
    lng: before.coords[0] + t * (after.coords[0] - before.coords[0]),
    exact: false, name: null,
    between: `zwischen ${before.name} (km ${before.km}) und ${after.name} (km ${after.km})`
  };
}

function jumpToKm(strecke, kmVal) {
  clearKmHighlight();
  const result = interpolateKm(strecke, kmVal);
  if (!result) return;
  map.setView([result.lat, result.lng], 14);
  const popupText = result.exact
    ? `<b>${result.name}</b><br>Strecke ${strecke} · km ${kmVal}`
    : `<b>km ${kmVal} · Strecke ${strecke}</b><br><small style="color:#888">interpoliert ${result.between}</small>`;
  kmHighlightMarker = L.circleMarker([result.lat, result.lng], {
    radius: 10, color: '#1a6fbb', fillColor: '#4a9de8', fillOpacity: 0.85, weight: 2
  }).bindPopup(popupText).addTo(map).openPopup();
  document.getElementById('jump-input').value = '';
  document.getElementById('jump-suggestions').innerHTML = '';
}

function showJumpSuggestions(val) {
  const box = document.getElementById('jump-suggestions');
  box.innerHTML = '';
  if (!val || val.length < 2) return;
  const q = val.toLowerCase();

  // km-Eingabe erkennen (z.B. "50,4" oder "50.4")
  const kmVal = parseKm(val);
  const isKmInput = !isNaN(kmVal) && /^[\d]+[,.]?\d*$/.test(val.trim());

  if (isKmInput) {
    const result = interpolateKm('5850', kmVal);
    if (result) {
      const btn = document.createElement('button');
      btn.textContent = result.exact
        ? `${result.name} · Strecke 5850 km ${kmVal}`
        : `km ${kmVal} · Strecke 5850 (interpoliert)`;
      btn.style.cssText = `
        background:#1a1f2e; border:1px solid #2a3148; border-radius:5px;
        padding:5px 9px; font-size:11px; color:#9ba3c0; cursor:pointer;
        text-align:left; font-family:inherit; transition:all 0.15s;
      `;
      btn.onmouseover = () => btn.style.borderColor = '#1a6fbb';
      btn.onmouseout  = () => btn.style.borderColor = '#2a3148';
      btn.onclick = () => jumpToKm('5850', kmVal);
      box.appendChild(btn);
    }
    return;
  }

  // Name- oder Streckensuche
  const matches = betriebsstellen.features.filter(f =>
    f.properties.name.toLowerCase().includes(q) ||
    f.properties.strecke.includes(q) ||
    f.properties.km.includes(q)
  ).slice(0, 5);
  matches.forEach(f => {
    const p = f.properties;
    const btn = document.createElement('button');
    btn.textContent = `${p.name} · ${p.strecke} km ${p.km}`;
    btn.style.cssText = `
      background:#1a1f2e; border:1px solid #2a3148; border-radius:5px;
      padding:5px 9px; font-size:11px; color:#9ba3c0; cursor:pointer;
      text-align:left; font-family:inherit; transition:all 0.15s;
    `;
    btn.onmouseover = () => btn.style.borderColor = '#e8542a';
    btn.onmouseout  = () => btn.style.borderColor = '#2a3148';
    btn.onclick = () => jumpToFeature(f);
    box.appendChild(btn);
  });
}

function jumpToFeature(f) {
  clearKmHighlight();
  const [lng, lat] = f.geometry.coordinates;
  map.setView([lat, lng], 14);
  const p = f.properties;
  kmHighlightMarker = L.circleMarker([lat, lng], {
    radius: 10, color: '#1a6fbb', fillColor: '#4a9de8', fillOpacity: 0.85, weight: 2
  }).bindPopup(`<b>${p.name}</b><br>Strecke ${p.strecke} · km ${p.km}`).addTo(map).openPopup();
  document.getElementById('jump-input').value = '';
  document.getElementById('jump-suggestions').innerHTML = '';
}

function jumpToFirst() {
  const val = document.getElementById('jump-input').value.trim();
  if (!val) return;
  const kmVal = parseKm(val);
  const isKmInput = !isNaN(kmVal) && /^[\d]+[,.]?\d*$/.test(val);
  if (isKmInput) {
    if (interpolateKm('5850', kmVal)) { jumpToKm('5850', kmVal); return; }
  }
  const q = val.toLowerCase();
  const match = betriebsstellen.features.find(f =>
    f.properties.name.toLowerCase().includes(q) ||
    f.properties.strecke.includes(q) ||
    f.properties.km.includes(q)
  );
  if (match) jumpToFeature(match);
}

// ── Auto-Zoom Toggle ──
function toggleAutoZoom() {
  autoZoom = !autoZoom;
  const btn = document.getElementById('autozoom-btn');
  btn.classList.toggle('on', autoZoom);
  if (autoZoom && boundingBox) {
    map.fitBounds(boundingBox.getBounds(), { padding: [60, 60], maxZoom: 16 });
  }
}

// ── Radius ──
const R_MIN = Math.log10(10), R_MAX = Math.log10(10000);
function sliderToRadius(v) { return Math.round(Math.pow(10, R_MIN + (v / 100) * (R_MAX - R_MIN))); }
function radiusToSlider(r) { return Math.round(((Math.log10(Math.max(10, Math.min(r, 10000))) - R_MIN) / (R_MAX - R_MIN)) * 100); }
function formatRadius(r) { return r < 1000 ? r.toLocaleString('de-DE') + ' m' : (r / 1000).toLocaleString('de-DE', {maximumFractionDigits: 1}) + ' km'; }

function onSliderChange(val) {
  currentRadius = sliderToRadius(parseFloat(val));
  document.getElementById('radius-display').textContent = formatRadius(currentRadius);
  syncPresetHighlight(currentRadius);
  recalculate();
}
function setRadius(r) {
  currentRadius = r;
  document.getElementById('radius-slider').value = radiusToSlider(r);
  document.getElementById('radius-display').textContent = formatRadius(r);
  syncPresetHighlight(r);
  recalculate();
}
const PRESETS = [10, 50, 100, 250, 500, 1000, 2500, 5000, 10000];
function syncPresetHighlight(r) {
  document.querySelectorAll('.preset-btn').forEach((b, i) => b.classList.toggle('active', PRESETS[i] === r));
}

// ── Location ──
function setLocation(lat, lng) {
  currentLat = lat; currentLng = lng;
  if (marker) map.removeLayer(marker);
  marker = L.circleMarker([lat, lng], {
    radius: 7, color: '#e8542a', fillColor: '#e8542a', fillOpacity: 1, weight: 2
  }).addTo(map);
  document.getElementById('map-hint').classList.add('hidden');
  document.getElementById('coords-display').textContent = lat.toFixed(6) + ', ' + lng.toFixed(6);
  document.getElementById('status-dot-map').classList.add('active');
  document.getElementById('status-dot').classList.add('active');
  recalculate();
}

function recalculate() {
  if (currentLat === null) return;
  const dLat = currentRadius / 111320;
  const dLng = currentRadius / (111320 * Math.cos(currentLat * DEG2RAD));
  const latMin = currentLat - dLat, latMax = currentLat + dLat;
  const lngMin = currentLng - dLng, lngMax = currentLng + dLng;
  setResult('val-lat-min', latMin);
  setResult('val-lat-max', latMax);
  setResult('val-long-min', lngMin);
  setResult('val-long-max', lngMax);
  if (boundingBox) map.removeLayer(boundingBox);
  boundingBox = L.rectangle([[latMin, lngMin],[latMax, lngMax]], {
    color: '#e8542a', weight: 2, fillColor: '#e8542a', fillOpacity: 0.08
  }).addTo(map);
  if (autoZoom) {
    map.fitBounds(boundingBox.getBounds(), { padding: [60, 60], maxZoom: 16 });
  }
}

function setResult(valId, val) {
  const el = document.getElementById(valId);
  el.textContent = val.toFixed(10).replace(/0+$/, '').replace(/\.$/, '');
  el.classList.remove('empty');
}

// ── Manual input ──
function parseGMaps() {
  const raw = document.getElementById('gmaps-input').value.trim();
  const match = raw.match(/(-?\d+[\.,]\d+)[,;\s]+(-?\d+[\.,]\d+)/);
  if (!match) { alert('Format nicht erkannt. Bitte "Lat, Long" eingeben.'); return; }
  const lat = parseFloat(match[1].replace(',', '.'));
  const lng = parseFloat(match[2].replace(',', '.'));
  map.setView([lat, lng], 14);
  setLocation(lat, lng);
}
document.getElementById('gmaps-input').addEventListener('keydown', e => { if (e.key === 'Enter') parseGMaps(); });

// ── Copy ──
function copyVal(id, btn) {
  const val = document.getElementById(id).textContent;
  if (val === '—') return;
  navigator.clipboard.writeText(val).then(() => {
    btn.textContent = '✓ Kopiert';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Kopieren'; btn.classList.remove('copied'); }, 1500);
  });
}

// ── Modals ──
function openDatenschutz() {
  document.getElementById('datenschutz-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeDatenschutz() {
  document.getElementById('datenschutz-modal').classList.remove('open');
  document.body.style.overflow = '';
}
function closeDatenschutzOnOverlay(e) {
  if (e.target === document.getElementById('datenschutz-modal')) closeDatenschutz();
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDatenschutz(); });
</script>

